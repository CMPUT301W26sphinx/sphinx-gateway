<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape>
            <solid android:color="#DCE4F7" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#C9D3EA" />
            <padding
                android:left="16dp"
                android:top="12dp"
                android:right="44dp"
                android:bottom="12dp" />
        </shape>
    </item>

    <item
        android:drawable="@drawable/ic_arrow_drop_down"
        android:gravity="end|center_vertical"
        android:right="14dp" />

</layer-list>