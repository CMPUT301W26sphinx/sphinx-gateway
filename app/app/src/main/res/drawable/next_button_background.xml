<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#2D63DD" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#1F4FB8" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#3B78F2" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#2A5FD0" />
        </shape>
    </item>
</selector>