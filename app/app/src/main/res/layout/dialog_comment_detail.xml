<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comment Details"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="User"
        android:textStyle="bold"
        android:textColor="#444444"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/dialog_user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Unknown"
        android:textSize="16sp"
        android:textColor="#222222"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Organizer"
        android:textStyle="bold"
        android:textColor="#444444"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/dialog_organizer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No"
        android:textSize="16sp"
        android:textColor="#222222"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comment"
        android:textStyle="bold"
        android:textColor="#444444"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/dialog_comment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Comment text"
        android:textSize="16sp"
        android:textColor="#222222"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Time"
        android:textStyle="bold"
        android:textColor="#444444"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/dialog_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2026-01-01 12:00:00"
        android:textSize="15sp"
        android:textColor="#222222"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">


            <Button
                android:id="@+id/dialog_cancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9E9E9E" />
        </LinearLayout>

        <Button
            android:id="@+id/dialog_delete"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Delete"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2D6EFF" />
    </LinearLayout>

</LinearLayout>