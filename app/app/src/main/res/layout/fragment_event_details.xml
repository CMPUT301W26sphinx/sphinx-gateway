<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UI.fragments.EventDetailsFragment">

    <!-- Title -->
    <TextView
        android:id="@+id/eventTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Placeholder - Event Name"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Info Button -->
    <ImageButton
        android:id="@+id/infoButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="8dp"
        android:contentDescription="Lottery System Information"
        android:background="@color/material_on_background_disabled"
        android:src="@drawable/ic_infoicon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/eventTitle"
        app:layout_constraintBottom_toTopOf="@id/buttonRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Poster -->
            <ImageView
                android:id="@+id/eventposter"
                android:layout_width="158dp"
                android:layout_height="202dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:contentDescription="No Event Poster Uploaded"
                android:src="@drawable/ic_emptyimageplaceholder"/>

            <!-- Info Column -->
            <LinearLayout
                android:id="@+id/eventInfoColumn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/editEventButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit Event"
                    android:backgroundTint="@color/nav_blue"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/labelStartTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/event_starttime_title"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/valueStartTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Placeholder"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/labelLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/event_location_title"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/valueLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Placeholder"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/labelDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/event_description_title"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/valueDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Placeholder"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/labelRegistration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/event_reg_title"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/valueRegistration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Placeholder"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/labelWaitlistCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/event_waitnum_title"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/valueWaitlistCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Placeholder"/>

                <Button
                    android:id="@+id/viewWaitlistButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View Waiting List"
                    android:backgroundTint="@color/nav_blue"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
            <!-- comments -->
            <TextView
                android:id="@+id/comments_title"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Comments"
                android:textSize="20dp">
            </TextView>

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:id="@+id/comment_recycler_view" >
            </androidx.recyclerview.widget.RecyclerView>

            <EditText
                android:id="@+id/write_comment_box"
                android:layout_width="match_parent"
                android:hint="Add a comment..."
                android:layout_height="wrap_content">

            </EditText>

            <Button
                android:id="@+id/add_comment_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:backgroundTint="@color/admin_nav_blue"
                android:text="+"
                android:textColor="@android:color/white"
                app:cornerRadius="20dp"
                app:rippleColor="@color/white">

            </Button>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/backbutton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="@string/backbutton"
            android:backgroundTint="@color/nav_blue"/>

        <Space
            android:layout_width="8dp"
            android:layout_height="match_parent"/>

        <Button
            android:id="@+id/registerbutton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="@string/registerbutton"
            android:backgroundTint="@color/nav_blue"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>