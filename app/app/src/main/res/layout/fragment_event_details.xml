<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.EventDetailsFragment">

    <TextView
        android:id="@+id/eventTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Placeholder - Event Name"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/infoButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="Lottery System Information"
        android:background="@color/material_on_background_disabled"
        android:src="@drawable/ic_infoicon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp"/>


    <!-- Content -->

    <ImageView
        android:id="@+id/eventposter"
        android:layout_width="196dp"
        android:layout_height="248dp"
        android:layout_marginTop="68dp"
        android:src="@drawable/ic_emptyimageplaceholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eventInfoColumn" />

    <LinearLayout
        android:id="@+id/eventInfoColumn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eventTitle">

        <!-- Description -->
        <TextView
            android:id="@+id/labelDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/event_description_title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/valueDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="Placeholder description from Firestore."
            android:textSize="14sp" />

        <!-- Registration period -->
        <TextView
            android:id="@+id/labelRegistration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/event_reg_title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/valueRegistration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="date – date, placeholder"
            android:textSize="14sp" />

        <!-- Waitlist count -->
        <TextView
            android:id="@+id/labelWaitlistCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/event_waitnum_title"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/valueWaitlistCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="xx placeholder for firestore"
            android:textSize="14sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eventposter">

        <Button
            android:id="@+id/backbutton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:backgroundTint="@color/main_blue"
            android:text="@string/backbutton" />

        <Space
            android:layout_width="8dp"
            android:layout_height="match_parent" />

        <Button
            android:id="@+id/registerbutton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:backgroundTint="@color/main_blue"
            android:text="@string/registerbutton" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>