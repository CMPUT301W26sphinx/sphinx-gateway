<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Title -->

    <TextView
        android:id="@+id/text_heading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Events"
        android:textSize="24sp"
        android:textStyle="bold"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="32dp"/>

    <!-- Subtitle -->

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Select an event to view details and register"
        android:textSize="16sp"

        app:layout_constraintTop_toBottomOf="@id/text_heading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="8dp"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="224dp"
        android:layout_height="52dp"

        android:layout_marginTop="16dp"
        android:background="@drawable/toggle_background"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle"

        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"

            android:backgroundTint="@color/toggle_button_color"
            android:text="All"
            android:textColor="@color/black"
            android:textSize="12sp"

            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMyEvents"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"

            android:backgroundTint="@color/toggle_button_color"
            android:text="My Events"
            android:textColor="@color/black"
            android:textSize="12sp"

            android:textStyle="bold" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Filter buttons -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/filterButton"
        android:layout_width="wrap_content"
        android:layout_height="41dp"

        android:text="Filter"
        android:textColor="#FFFFFF"
        android:textSize="14sp"

        android:backgroundTint="#2D6EFF"

        app:icon="@drawable/ic_close"
        app:iconGravity="textEnd"
        app:iconPadding="6dp"
        app:iconTint="#FFFFFF"
        app:cornerRadius="20dp"

        app:layout_constraintTop_toBottomOf="@id/toggleGroup"
        app:layout_constraintStart_toStartOf="parent"

        android:layout_marginTop="20dp"
        android:layout_marginStart="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/filterSetButton"
        android:layout_width="wrap_content"
        android:layout_height="41dp"

        android:text="Filter"
        android:textColor="#FFFFFF"
        android:textSize="14sp"

        android:backgroundTint="#2D6EFF"

        app:icon="@drawable/ic_filter"
        app:iconGravity="textEnd"
        app:iconPadding="6dp"
        app:iconTint="#FFFFFF"
        app:cornerRadius="20dp"

        app:layout_constraintTop_toBottomOf="@id/toggleGroup"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="20dp"
        android:layout_marginEnd="32dp"/>

    <!-- Event list items -->

    <EditText
        android:id="@+id/event_search_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        app:layout_constraintEnd_toStartOf="@+id/event_search_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eventsRecyclerView">

    </EditText>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/eventsRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="100dp"
        android:paddingTop="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterButton" />


    <TextView
        android:id="@+id/empty_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No matching events"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filterSetButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"

        />

    <Button
        android:id="@+id/event_search_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/admin_nav_blue"
        android:text="Search"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/eventsRecyclerView" />


</androidx.constraintlayout.widget.ConstraintLayout>