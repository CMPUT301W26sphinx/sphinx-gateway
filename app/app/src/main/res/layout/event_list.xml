<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavigationView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
    </FrameLayout>
    <!-- Title -->

    <TextView
        android:id="@+id/text_heading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Events"
        android:textSize="24sp"
        android:textStyle="bold"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="32dp"/>

    <!-- Subtitle -->

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:text="Select an event to view details and register"
        android:textSize="16sp"

        app:layout_constraintTop_toBottomOf="@id/text_heading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="8dp"/>

    <!-- Toggle -->

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggleGroup"
        android:layout_width="224dp"
        android:layout_height="52dp"

        android:layout_marginTop="16dp"
        android:background="@drawable/toggle_background"

        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"

            android:text="All"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"

            android:backgroundTint="@android:color/transparent"
            app:cornerRadius="25dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMyEvents"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"

            android:text="My Events"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"

            android:backgroundTint="@android:color/transparent"
            app:cornerRadius="25dp"/>

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Filter buttons -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/filterButton"
        android:layout_width="wrap_content"
        android:layout_height="41dp"

        android:text="Filter"
        android:textColor="#FFFFFF"
        android:textSize="14sp"

        android:backgroundTint="#2D6EFF"

        app:icon="@drawable/ic_close"
        app:iconGravity="textEnd"
        app:iconPadding="6dp"
        app:iconTint="#FFFFFF"
        app:cornerRadius="20dp"

        app:layout_constraintTop_toBottomOf="@id/toggleGroup"
        app:layout_constraintStart_toStartOf="parent"

        android:layout_marginTop="20dp"
        android:layout_marginStart="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/filterSetButton"
        android:layout_width="wrap_content"
        android:layout_height="41dp"

        android:text="Filter"
        android:textColor="#FFFFFF"
        android:textSize="14sp"

        android:backgroundTint="#2D6EFF"

        app:icon="@drawable/ic_filter"
        app:iconGravity="textEnd"
        app:iconPadding="6dp"
        app:iconTint="#FFFFFF"
        app:cornerRadius="20dp"

        app:layout_constraintTop_toBottomOf="@id/toggleGroup"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="20dp"
        android:layout_marginEnd="32dp"/>

    <!-- Event list items -->

    <TextView
        android:id="@+id/list_item_1"
        android:layout_width="0dp"
        android:layout_height="72dp"

        android:background="@drawable/drawable_list_item_1"
        android:text="@string/eventname"

        app:layout_constraintTop_toBottomOf="@id/filterButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>

    <TextView
        android:id="@+id/list_item_2"
        android:layout_width="0dp"
        android:layout_height="72dp"

        android:layout_marginStart="24dp"
        android:layout_marginTop="0dp"

        android:layout_marginEnd="24dp"
        android:background="@drawable/drawable_list_item_1"
        android:text="@string/eventname"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/list_item_1" />

    <TextView
        android:id="@+id/list_item_3"
        android:layout_width="0dp"
        android:layout_height="72dp"

        android:background="@drawable/drawable_list_item_1"
        android:text="@string/eventname"

        app:layout_constraintTop_toBottomOf="@id/list_item_2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>

    <TextView
        android:id="@+id/list_item_4"
        android:layout_width="0dp"
        android:layout_height="72dp"

        android:background="@drawable/drawable_list_item_1"
        android:text="@string/eventname"

        app:layout_constraintTop_toBottomOf="@id/list_item_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>

    <TextView
        android:id="@+id/list_item_5"
        android:layout_width="0dp"
        android:layout_height="72dp"

        android:background="@drawable/drawable_list_item_1"
        android:text="@string/eventname"

        app:layout_constraintTop_toBottomOf="@id/list_item_4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        android:layout_marginTop="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"/>

    <!-- Last event item -->


    <TextView
        android:id="@+id/list_item_6"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginStart="24dp"

        android:layout_marginEnd="24dp"
        android:background="@drawable/drawable_list_item_1"
        android:text="Event Name\nEvent description"

        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/list_item_5"
        app:layout_constraintVertical_bias="0.0" />


    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#036BF4"
        app:itemActiveIndicatorStyle="@null"
        app:itemIconTint="@color/white"

        app:itemTextColor="@color/white"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintHorizontal_bias="0.0"


        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />
</androidx.constraintlayout.widget.ConstraintLayout>