<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#ffffff">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff">

        <!-- Event Title -->
        <TextView
            android:id="@+id/event_detail_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Event Name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <!-- Description -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/event_detail_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event description"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Registration Period -->
        <TextView
            android:id="@+id/event_registration_period"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registration Period: 2025-03-01 - 2025-03-15"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <!-- Waiting List -->
        <TextView
            android:id="@+id/event_waiting_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting List: 5 users"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Event Poster (placeholder) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Event Poster"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <ImageView
            android:id="@+id/event_poster"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:background="#e0e0e0"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_placeholder"
            android:layout_marginBottom="24dp" />

        <!-- Buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/back_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Back"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#2d6eff"/>

            <Button
                android:id="@+id/remove_event_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Remove Event"
                android:layout_marginStart="8dp"
                android:backgroundTint="#2d6eff"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>